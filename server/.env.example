# Copy to .env and adjust. The server reads these on startup.

# --- Database ---
# PostgreSQL (production/target). Requires a running Postgres reachable at this URL.
DATABASE_URL=postgresql+psycopg://autoreply:autoreply@localhost:5432/autoreply
# For quick local testing without Postgres you may use SQLite instead:
# DATABASE_URL=sqlite:///./autoreply.db

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MIN=720

# --- Folders (created automatically if missing) ---
# main/ is watched by the watcher AND holds the permanent tree main/<user>/<request_id>/.
# Drop raw response files directly in main/ (top level) for auto-routing.
MAIN_DIR=./main
UNMATCHED_DIR=./unmatched

# --- Networking (LAN) ---
# Comma-separated allowed origins for the Next.js apps. Use the server LAN IP.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Bootstrap admin (used by seed_admin.py) ---
ADMIN_USER_ID=admin
ADMIN_PASSWORD=admin123
ADMIN_ZONE=HQ
